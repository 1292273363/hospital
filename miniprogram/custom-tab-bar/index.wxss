.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1rpx solid #e8e8e8;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
}

.tab-bar-inner {
  display: flex;
  height: 96rpx;
  align-items: center;
  justify-content: space-around;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 96rpx;
}

.tab-icon {
  font-size: 36rpx;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #888888;
  line-height: 1.2;
}

.tab-item.active .tab-text {
  color: #43a294;
  font-weight: 600;
}
