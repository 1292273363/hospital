<view class="patient-chat-page">
  <view class="card">
    <view class="title">当前患者</view>
    <view class="patient">{{currentPatient ? currentPatient.patientName : '未选择患者档案'}}</view>
    <button wx:if="{{!currentPatient}}" class="btn" bindtap="goSelectPatient">去选择患者</button>
    <button wx:else class="btn outline" bindtap="goConsult">去发起问诊</button>
  </view>

  <view class="card">
    <view class="title">沟通记录</view>
    <view class="empty" wx:if="{{!historyList.length}}">暂无沟通记录</view>
    <view class="item" wx:for="{{historyList}}" wx:key="id">
      <view class="time">{{item.createTime}} · {{item.status}}</view>
      <view class="line"><text class="k">我的留言：</text>{{item.patientMessage || '无'}}</view>
      <view class="line"><text class="k">医生回复：</text>{{item.doctorReply || '暂未回复'}}</view>
      <image wx:if="{{item.scarImageUrl}}" class="img" src="{{item.scarImageUrl}}" mode="aspectFill" />
    </view>
  </view>
</view>
