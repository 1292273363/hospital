<view class="upload-container">
  <view class="card">
    <view class="title">{{pageTitle}}</view>

    <view class="form-item">
      <text class="label">患者姓名</text>
      <input class="input" placeholder="请输入患者姓名" value="{{form.patientName}}" data-field="patientName" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genderOptions}}" range-key="label" value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="picker">{{genderOptions[genderIndex].label}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">年龄</text>
      <input class="input" type="number" placeholder="请输入年龄" value="{{form.age}}" data-field="age" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="label">联系电话</text>
      <input class="input" type="number" placeholder="请输入联系电话" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="label">病种</text>
      <input class="input" placeholder="例如：高血压、糖尿病" value="{{form.diseaseType}}" data-field="diseaseType" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="label">身份证号</text>
      <input class="input" placeholder="请输入身份证号（可选）" value="{{form.idCard}}" data-field="idCard" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="label">就诊备注</text>
      <textarea class="textarea" placeholder="请输入备注信息（可选）" value="{{form.remark}}" data-field="remark" bindinput="onInput" />
    </view>

    <button class="submit-btn" loading="{{submitting}}" bindtap="onSubmit">{{mode === 'edit' ? '保存修改' : '提交新增'}}</button>
  </view>
</view>
