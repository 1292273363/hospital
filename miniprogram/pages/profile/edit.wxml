<view class="profile-container">
  <view class="card">
    <view class="title">修改密码</view>

    <view class="form-item">
      <text class="label">旧密码</text>
      <input class="input" password placeholder="请输入旧密码" value="{{form.oldPassword}}" data-field="oldPassword" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="label">新密码</text>
      <input class="input" password placeholder="请输入新密码（4-20位）" value="{{form.newPassword}}" data-field="newPassword" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="label">确认新密码</text>
      <input class="input" password placeholder="请再次输入新密码" value="{{form.confirmPassword}}" data-field="confirmPassword" bindinput="onInput" />
    </view>

    <button class="submit-btn" loading="{{submitting}}" bindtap="onSubmit">保存新密码</button>
  </view>
</view>
