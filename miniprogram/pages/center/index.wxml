<view class="center-container">
  <view class="header">
    <view class="avatar-wrap" bindtap="onAvatarTap">
      <image wx:if="{{userInfo.avatarUrl}}" class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-placeholder">头像</view>
    </view>
    <view class="detail">
      <text class="name">{{userInfo.nickName || '微信用户'}}</text>
      <text class="phone">{{userInfo.phone || '未绑定手机号'}}</text>
      <text class="patient">当前患者：{{currentPatient ? currentPatient.patientName : '未选择'}}</text>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" bindtap="goProfile">
      <text>个人中心</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goPatient">
      <text>患者档案</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item danger" bindtap="onLogout">
      <text>退出登录</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
