/* 个人中心 — medical 主题（对齐参考 HTML） */
page {
  background-color: #f0f9f8;
}

.center-page {
  min-height: 100vh;
  background: #f0f9f8;
  padding-bottom: calc(32rpx + 120rpx + env(safe-area-inset-bottom));
}

.content-pad {
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 0 20rpx 0 rgba(225, 231, 243, 0.9);
  margin-bottom: 40rpx;
  overflow: hidden;
}

/* 用户卡 */
.card-user {
  padding: 40rpx;
}

.user-row {
  display: flex;
  align-items: center;
}

.avatar-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #d1f0ec;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-ph {
  background: #d1f0ec;
  color: #248274;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-text {
  margin-left: 32rpx;
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.user-sub {
  font-size: 26rpx;
  color: #888888;
  margin-top: 8rpx;
  display: block;
}

.stats-row {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #f0f0f0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stat-cell {
  text-align: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #248274;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: #888888;
  margin-top: 8rpx;
  display: block;
}

/* 菜单列表 */
.card-menu {
  padding: 0;
}

.menu-line {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-line-last {
  border-bottom: none;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.menu-icon-blue {
  background: #e6f4ff;
}

.menu-icon-green {
  background: #f6ffed;
}

.menu-icon-purple {
  background: #f9f0ff;
}

.menu-icon-orange {
  background: #fff7e6;
}

.menu-icon-cyan {
  background: #e6fffb;
}

.menu-icon-gray {
  background: #f5f5f5;
}

.menu-title {
  flex: 1;
  margin-left: 24rpx;
  font-size: 32rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
  font-weight: 300;
}

/* 退出 */
.logout-btn {
  width: 100%;
  margin: 0;
  padding: 28rpx;
  background: #ffffff;
  color: #ff4d4f;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  box-shadow: 0 0 20rpx 0 rgba(225, 231, 243, 0.9);
  border: none;
  line-height: 1.4;
}

.logout-btn::after {
  border: none;
}

.version-text {
  text-align: center;
  font-size: 22rpx;
  color: #bbbbbb;
  margin-top: 48rpx;
}
