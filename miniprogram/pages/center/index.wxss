.center-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.header {
  background: linear-gradient(135deg, #1AAD19 0%, #0d8a0c 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 108rpx;
  height: 108rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.7);
}

.avatar-placeholder {
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.25);
}

.detail {
  margin-left: 24rpx;
}

.name {
  display: block;
  font-size: 34rpx;
  color: #fff;
  font-weight: 700;
}

.phone {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 10rpx;
}

.patient {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
}

.menu-card {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.arrow {
  color: #aaa;
}

.danger {
  color: #e53935;
}
