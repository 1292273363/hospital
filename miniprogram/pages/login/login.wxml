<!-- pages/login/login.wxml -->
<view class="login-container">
  <!-- 顶部装饰背景 -->
  <view class="top-bg">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
    <view class="circle circle-3"></view>
  </view>

  <!-- Logo区域 -->
  <view class="logo-area">
    <image class="logo-icon" src="/images/hospital-logo.png" mode="aspectFit" />
    <text class="app-name">医院服务平台</text>
    <text class="app-slogan">您的健康，我们守护</text>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <view class="card-title">欢迎使用</view>
    <view class="card-subtitle">一键登录，快速体验全部服务</view>

    <!-- 功能特性 -->
    <view class="feature-list">
      <view class="feature-item">
        <view class="feature-icon">🏥</view>
        <text class="feature-text">在线挂号</text>
      </view>
      <view class="feature-item">
        <view class="feature-icon">📋</view>
        <text class="feature-text">查看报告</text>
      </view>
      <view class="feature-item">
        <view class="feature-icon">💊</view>
        <text class="feature-text">用药提醒</text>
      </view>
      <view class="feature-item">
        <view class="feature-icon">📞</view>
        <text class="feature-text">在线问诊</text>
      </view>
    </view>

    <!-- 微信一键登录按钮 -->
    <button
      class="wx-login-btn {{isLoading ? 'loading' : ''}}"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneNumber"
      disabled="{{isLoading}}"
    >
      <view class="btn-inner">
        <image class="wechat-icon" src="/images/wechat-icon.png" mode="aspectFit" wx:if="{{!isLoading}}" />
        <view class="loading-spinner" wx:if="{{isLoading}}"></view>
        <text class="btn-text">{{isLoading ? '登录中...' : '微信一键登录'}}</text>
      </view>
    </button>

    <button class="doctor-login-btn" bindtap="goDoctorLogin" disabled="{{isLoading}}">
      医生登录入口
    </button>

    <!-- 协议 -->
    <view class="agreement">
      <view class="checkbox-area" bindtap="toggleAgree">
        <view class="checkbox {{agreed ? 'checked' : ''}}"></view>
      </view>
      <text class="agree-text">已阅读并同意</text>
      <text class="link-text" bindtap="openUserAgreement">《用户协议》</text>
      <text class="agree-text">和</text>
      <text class="link-text" bindtap="openPrivacyPolicy">《隐私政策》</text>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer">
    <text class="footer-text">登录即代表您的信息仅用于本平台服务</text>
  </view>
</view>

