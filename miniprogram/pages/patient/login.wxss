.patient-login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #e8f4f2 0%, #f1f8f6 40%, #ffffff 100%);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.header {
  margin-top: 20rpx;
  margin-bottom: 28rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7d8b8a;
}

.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx 30rpx;
  box-shadow: 0 12rpx 40rpx rgba(67, 162, 148, 0.12);
}

.field-label {
  font-size: 26rpx;
  color: #5c6665;
  margin-bottom: 10rpx;
}

.input-wrap {
  height: 86rpx;
  border: 2rpx solid #d6ebe8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
  margin-bottom: 22rpx;
  background: #fbfffe;
}

.input-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #2d3436;
}

.input-ph {
  color: #a0b1b0;
}

.login-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 46rpx;
  border: none;
  background: linear-gradient(135deg, #4ecdc4, #38a89d);
  margin-top: 6rpx;
}

.login-btn::after {
  border: none;
}

.login-btn-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.tip {
  margin-top: 20rpx;
  text-align: center;
  color: #92a5a3;
  font-size: 22rpx;
}
