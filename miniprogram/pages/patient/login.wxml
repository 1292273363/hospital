<view class="patient-login-page">
  <view class="header">
    <view class="title">患者登录</view>
    <view class="sub">新用户将自动注册，初始密码为手机号后4位</view>
  </view>

  <view class="card">
    <view class="field-label">手机号</view>
    <view class="input-wrap">
      <text class="input-icon">📱</text>
      <input
        class="input-field"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="input-ph"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="field-label">密码</view>
    <view class="input-wrap">
      <text class="input-icon">🔒</text>
      <input
        class="input-field"
        password
        placeholder="请输入密码"
        placeholder-class="input-ph"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <button class="login-btn" bindtap="submitLogin" loading="{{loggingIn}}" disabled="{{loggingIn}}">
      <text class="login-btn-text">登录</text>
    </button>

    <view class="tip">首次登录请使用手机号后4位作为密码</view>
  </view>
</view>
