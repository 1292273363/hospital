.patient-container {
  min-height: 100vh;
  background: #f5fbf9;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
}

.title {
  font-size: 30rpx;
  color: #333;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.empty {
  color: #999;
  font-size: 26rpx;
  padding: 20rpx 0;
}

.item {
  border: 1rpx solid #ececec;
  border-radius: 14rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.active {
  border-color: #43a294;
  background: #f4fbf9;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.tag {
  font-size: 22rpx;
  color: #43a294;
}

.desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.actions {
  margin-top: 14rpx;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  background: #f0f7f5;
  color: #43a294;
  font-size: 24rpx;
}

.action-btn.danger {
  background: #fff2f2;
  color: #e53935;
}

.btn {
  margin-top: 12rpx;
  background: #43a294;
  color: #fff;
  border-radius: 42rpx;
}
