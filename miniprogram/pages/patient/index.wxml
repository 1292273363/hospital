<view class="patient-container">
  <view class="card">
    <view class="title">请选择当前患者档案</view>
    <view class="empty" wx:if="{{!patients.length}}">暂无患者档案，请先去上传页新增</view>
    <view class="item {{currentPatientId===item.id ? 'active' : ''}}" wx:for="{{patients}}" wx:key="id" bindtap="onSelect" data-id="{{item.id}}">
      <view class="row">
        <text class="name">{{item.patientName}}</text>
        <text class="tag">{{currentPatientId===item.id ? '当前使用' : '点击使用'}}</text>
      </view>
      <view class="desc">病种：{{item.diseaseType || '未填写'}} ｜ 电话：{{item.phone || '未填写'}}</view>
      <view class="actions">
        <view class="action-btn" catchtap="onEdit" data-id="{{item.id}}">修改</view>
        <view class="action-btn danger" catchtap="onDelete" data-id="{{item.id}}">删除</view>
      </view>
    </view>
    <button class="btn" bindtap="onCreate">新增患者档案</button>
  </view>
</view>
