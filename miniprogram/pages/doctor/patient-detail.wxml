<view class="detail-page" wx:if="{{patient}}">
  <view class="card main-card">
    <view class="row top-row">
      <view class="avatar">{{patient.avatarText}}</view>
      <view class="info">
        <view class="name-row">
          <text class="name">{{patient.name}}</text>
          <text class="status-tag {{patient.statusClass}}">{{patient.status}}</text>
        </view>
        <text class="meta">{{patient.gender}} · {{patient.age}}岁</text>
        <text class="meta">手机号：{{patient.phone}}</text>
        <text class="meta">就诊日期：{{patient.date}}</text>
      </view>
    </view>
  </view>

  <view class="card section-card">
    <view class="section-title">咨询项目</view>
    <text class="project">{{patient.project}}</text>
  </view>

  <view class="card section-card">
    <view class="section-title">基本信息</view>
    <view class="field-row">
      <text class="field-label">姓名</text>
      <text class="field-value">{{patient.name}}</text>
    </view>
    <view class="field-row">
      <text class="field-label">性别</text>
      <text class="field-value">{{patient.gender}}</text>
    </view>
    <view class="field-row">
      <text class="field-label">年龄</text>
      <text class="field-value">{{patient.age}} 岁</text>
    </view>
    <view class="field-row">
      <text class="field-label">联系电话</text>
      <text class="field-value">{{patient.phone}}</text>
    </view>
    <view class="field-row">
      <text class="field-label">最近就诊时间</text>
      <text class="field-value">{{patient.date}}</text>
    </view>
  </view>
</view>

<view class="empty" wx:else>
  <text>未找到该患者信息</text>
</view>

