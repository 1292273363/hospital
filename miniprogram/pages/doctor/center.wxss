.doctor-center-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 28rpx;
  box-sizing: border-box;
}

.profile-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 24rpx;
}

.name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 14rpx;
}

.line {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.menu-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger {
  color: #e34d59;
}

.arrow {
  color: #bbb;
}
