/* 医生个人中心 — medical 主题（对齐参考 HTML） */
page {
  background-color: #f0f9f8;
}

.doctor-center-page {
  min-height: 100vh;
  background: #f0f9f8;
  padding: 32rpx;
  padding-bottom: calc(40rpx + 120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 0 20rpx 0 rgba(225, 231, 243, 0.9);
  margin-bottom: 40rpx;
  overflow: hidden;
}

/* 渐变头 */
.profile-card {
  padding: 0;
}

.profile-hero {
  background: linear-gradient(90deg, #49bcac 0%, #248274 100%);
  padding: 48rpx 40rpx;
}

.hero-inner {
  display: flex;
  align-items: center;
}

.hero-avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.35);
  overflow: hidden;
  flex-shrink: 0;
}

.hero-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.hero-avatar-ph {
  background: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-text {
  margin-left: 32rpx;
  flex: 1;
  min-width: 0;
}

.hero-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
  display: block;
  margin-bottom: 8rpx;
}

.hero-license {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

/* 统计 2×2 */
.profile-stats {
  padding: 32rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stat-cell {
  background: #f0f9f8;
  border-radius: 12rpx;
  padding: 24rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #888888;
  display: block;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f685e;
  display: block;
}

/* 菜单 */
.menu-card {
  padding: 0;
}

.menu-line {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-line-last {
  border-bottom: none;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.menu-icon-blue {
  background: #e6f4ff;
}

.menu-icon-blue2 {
  background: #e6f4ff;
}

.menu-icon-green {
  background: #f6ffed;
}

.menu-icon-purple {
  background: #f9f0ff;
}

.menu-icon-orange {
  background: #fff7e6;
}

.menu-icon-yellow {
  background: #feffe6;
}

.menu-icon-gray {
  background: #f5f5f5;
}

.menu-icon-red {
  background: #fff1f0;
}

.menu-title {
  flex: 1;
  margin-left: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
  font-weight: 300;
}

.logout-card {
  margin-bottom: 0;
}

.logout-line {
  padding-top: 28rpx;
  padding-bottom: 28rpx;
}

.logout-title {
  color: #ff4d4f;
}
