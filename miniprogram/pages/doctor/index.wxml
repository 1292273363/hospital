<view class="doctor-page">
  <!-- 欢迎横幅 -->
  <view class="welcome-card">
    <view class="welcome-row">
      <view class="welcome-left">
        <text class="welcome-greet">{{greeting}}，{{displayName}}</text>
        <view class="welcome-line2">
          <text class="welcome-sub">今天有</text>
          <text class="welcome-num">{{pendingTotal}}</text>
          <text class="welcome-sub">位患者等待您处理</text>
        </view>
      </view>
      <view class="welcome-right">
        <text class="date-line">{{dateStr}}</text>
        <text class="date-line">{{weekdayStr}}</text>
      </view>
    </view>
  </view>

  <!-- 今日待处理 -->
  <view class="section-card">
    <view class="section-head">
      <text class="section-title">今日待处理</text>
      <view class="section-more" bindtap="onViewAll">
        <text>查看全部</text>
        <text class="chev">›</text>
      </view>
    </view>
    <view class="patient-list">
      <view
        class="patient-item"
        wx:for="{{pendingList}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onPatientTap"
      >
        <view class="patient-avatar">{{item.avatarText}}</view>
        <view class="patient-main">
          <view class="patient-row1">
            <text class="patient-name">{{item.name}}</text>
            <text class="tag {{item.tagClass}}">{{item.tag}}</text>
          </view>
          <text class="patient-desc">{{item.desc}}</text>
        </view>
        <text class="patient-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 快捷功能 3 列 -->
  <view class="quick-section">
    <text class="quick-heading">快捷功能</text>
    <view class="quick-grid">
      <view class="quick-item" bindtap="onQuick" data-action="patients">
        <view class="quick-icon-wrap bg-medical">
          <text class="quick-emoji">👥</text>
        </view>
        <text class="quick-label">患者管理</text>
      </view>
      <view class="quick-item" bindtap="onQuick" data-action="diagnosis">
        <view class="quick-icon-wrap bg-blue">
          <text class="quick-emoji">📋</text>
        </view>
        <text class="quick-label">诊断记录</text>
      </view>
      <view class="quick-item" bindtap="onQuick" data-action="notify">
        <view class="quick-icon-wrap bg-yellow rel">
          <text class="quick-emoji">🔔</text>
          <view class="notify-badge">3</view>
        </view>
        <text class="quick-label">通知</text>
      </view>
      <view class="quick-item" bindtap="onQuick" data-action="chat">
        <view class="quick-icon-wrap bg-green">
          <text class="quick-emoji">💬</text>
        </view>
        <text class="quick-label">在线聊天</text>
      </view>
    </view>
  </view>

  <!-- 本周统计 -->
  <view class="section-card stats-card">
    <text class="section-title stats-title">本周统计</text>
    <view class="stats-grid">
      <view class="stat-box" wx:for="{{weekStats}}" wx:key="label">
        <text class="stat-num">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>
</view>
