<view class="detail-page" wx:if="{{record}}">
  <view class="card main-card">
    <view class="title-row">
      <text class="title-main">档案详情</text>
      <text class="title-sub">{{record.date}}</text>
    </view>
    <view class="file-block">
      <view class="file-icon">{{record.type === 'image' ? '图' : '文'}}</view>
      <view class="file-info">
        <text class="file-name">{{record.name}}</text>
        <text class="file-meta">所属患者：{{patientName}}</text>
      </view>
    </view>
  </view>

  <view class="card section-card">
    <view class="section-title">档案说明</view>
    <text class="desc">{{record.remark}}</text>
  </view>

  <view class="card section-card">
    <view class="section-title">示例预览</view>
    <view class="preview-box">
      <text class="preview-tip">
        当前为模拟数据，真实环境下可在此展示图片、PDF 预览或跳转到原始文件。
      </text>
    </view>
  </view>
</view>

<view class="empty" wx:else>
  <text>未找到档案信息</text>
</view>

