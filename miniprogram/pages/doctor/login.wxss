/* 整形医院医生端 — 主题色 #43A294 / 背景 #F5FBF9 */
page {
  background-color: #f5fbf9;
}

.doctor-login-page {
  min-height: 100vh;
  background: #f5fbf9;
  padding: 48rpx 40rpx 80rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.header-icon-wrap {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: #43a294;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(67, 162, 148, 0.35);
}

.header-icon-inner {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-icon-symbol {
  font-size: 52rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1;
}

.header-title {
  margin-top: 28rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a4d45;
  letter-spacing: 2rpx;
}

.header-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #7a9a94;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(40, 90, 85, 0.08);
}

.tabs {
  display: flex;
  border-bottom: 2rpx solid #e8f2f0;
  margin-bottom: 36rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding-bottom: 20rpx;
  font-size: 30rpx;
  color: #9cb5b0;
  position: relative;
}

.tab-active {
  color: #43a294;
  font-weight: 600;
}

.tab-active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 56rpx;
  height: 6rpx;
  background: #43a294;
  border-radius: 4rpx;
}

.field-label {
  font-size: 28rpx;
  color: #4a5c58;
  margin-bottom: 16rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  background: #ffffff;
  border: 2rpx solid #e0ebe8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 88rpx;
  box-sizing: border-box;
  margin-bottom: 28rpx;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.85;
}

.input-field {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  color: #1a4d45;
}

.input-ph {
  color: #b0c5c0;
}

/* 图二：验证码行 ≈ 输入 65% + 间距 + 按钮 35% */
.code-row {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  margin-bottom: 0;
}

.code-row .input-wrap {
  margin-bottom: 0;
}

.code-input-wrap {
  flex: 13 1 0%;
  min-width: 0;
  margin-bottom: 0;
}

.code-btn {
  flex: 7 1 0%;
  min-width: 0;
  height: 88rpx;
  padding: 0 8rpx;
  margin: 0;
  font-size: 0;
  font-weight: 500;
  color: #ffffff;
  background: #43a294;
  border-radius: 12rpx;
  border: none;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.code-btn-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  line-height: 1.25;
}

.code-btn::after {
  border: none;
}

.code-btn[disabled] {
  background: #a8d0c8;
  color: #ffffff;
}

.code-btn[disabled] .code-btn-text {
  color: #ffffff;
}

/* 图二：主按钮与上方输入区同宽，略增高 */
.login-btn {
  margin-top: 36rpx;
  width: 100%;
  height: 100rpx;
  padding: 0 !important;
  border-radius: 12rpx;
  border: none;
  color: #ffffff;
  background: #43a294;
  font-size: 0;
  font-weight: 600;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.login-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  opacity: 0.75;
}

/* 图二底部：左蓝字 / 右主题色 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 8rpx;
}

.card-footer-link {
  font-size: 24rpx;
  color: #43a294;
}

.card-footer-link-blue {
  color: #576b95;
}
