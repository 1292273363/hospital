page {
  background-color: #f0f9f8;
}

.patients-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.search-wrap {
  position: relative;
  margin-bottom: 28rpx;
}

.search-icon {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  z-index: 1;
  pointer-events: none;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 28rpx 0 72rpx;
  background: #ffffff;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.search-input:focus {
  border-color: #30a392;
}

.search-ph {
  color: #bbbbbb;
}

.filter-scroll {
  width: 100%;
  margin-bottom: 28rpx;
  white-space: nowrap;
}

.filter-inner {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.filter-chip {
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #666666;
  background: #ffffff;
  border: 2rpx solid #e8e8e8;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.filter-chip-on {
  background: #30a392;
  color: #ffffff;
  border-color: #30a392;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.patient-card {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 0 20rpx 0 rgba(225, 231, 243, 0.9);
  padding: 32rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
}

.p-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #d1f0ec;
  color: #248274;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.p-info {
  flex: 1;
  min-width: 0;
}

.p-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.p-meta {
  font-size: 24rpx;
  color: #888888;
  margin-top: 8rpx;
  display: block;
}

.p-tags {
  margin-top: 12rpx;
}

.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.st-pending {
  background: #fffbe6;
  color: #d48806;
}

.st-treating {
  background: #e6f4ff;
  color: #1677ff;
}

.st-done {
  background: #f6ffed;
  color: #389e0d;
}

.p-date {
  font-size: 22rpx;
  color: #bbbbbb;
  flex-shrink: 0;
}

.card-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 24rpx 0;
}

.p-project {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 24rpx;
}

.card-actions {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  margin: 0;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 8rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-outline {
  background: #f0f9f8;
  color: #248274;
}

.btn-primary {
  background: #30a392;
  color: #ffffff;
}

.load-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 26rpx;
  color: #bbbbbb;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #999999;
}
