page {
  background-color: #f0f9f8;
}

.detail-page {
  padding: 32rpx 28rpx 40rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 0 20rpx rgba(225, 231, 243, 0.9);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-main {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.title-sub {
  font-size: 24rpx;
  color: #999999;
}

.file-block {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
}

.file-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #d1f0ec;
  color: #248274;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.file-info {
  flex: 1;
}

.file-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
}

.file-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999999;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 26rpx;
  color: #666666;
}

.preview-box {
  padding: 32rpx;
  border-radius: 12rpx;
  background: #f5fbf9;
}

.preview-tip {
  font-size: 24rpx;
  color: #888888;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #999999;
}

