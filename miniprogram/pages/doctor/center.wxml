<view class="doctor-center-page">
  <!-- 个人信息：渐变头 + 统计 -->
  <view class="card profile-card">
    <view class="profile-hero">
      <view class="hero-inner">
        <view class="hero-avatar-wrap">
          <image
            wx:if="{{userInfo.avatarUrl}}"
            class="hero-avatar"
            src="{{userInfo.avatarUrl}}"
            mode="aspectFill"
          />
          <view wx:else class="hero-avatar hero-avatar-ph">医</view>
        </view>
        <view class="hero-text">
          <text class="hero-name">{{displayName}}</text>
          <text class="hero-title">{{doctorTitle}}</text>
          <text class="hero-license">执业证书编号: {{licenseNo}}</text>
        </view>
      </view>
    </view>
    <view class="profile-stats">
      <view class="stat-grid">
        <view class="stat-cell">
          <text class="stat-label">从业年限</text>
          <text class="stat-value">{{stats.years}}</text>
        </view>
        <view class="stat-cell">
          <text class="stat-label">完成手术</text>
          <text class="stat-value">{{stats.surgeries}}</text>
        </view>
        <view class="stat-cell">
          <text class="stat-label">擅长领域</text>
          <text class="stat-value">{{stats.specialty}}</text>
        </view>
        <view class="stat-cell">
          <text class="stat-label">患者满意度</text>
          <text class="stat-value">{{stats.satisfaction}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="card menu-card">
    <view class="menu-line" bindtap="goChat">
      <view class="menu-icon menu-icon-blue">💬</view>
      <text class="menu-title">在线沟通</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-line" bindtap="onAccountSettings">
      <view class="menu-icon menu-icon-blue2">⚙️</view>
      <text class="menu-title">账号设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-line" bindtap="onSchedule">
      <view class="menu-icon menu-icon-green">📅</view>
      <text class="menu-title">我的排班</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-line" bindtap="onReviews">
      <view class="menu-icon menu-icon-purple">⭐</view>
      <text class="menu-title">我的评价</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-line" bindtap="onNotifySettings">
      <view class="menu-icon menu-icon-orange">🔔</view>
      <text class="menu-title">消息通知设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-line" bindtap="onHelp">
      <view class="menu-icon menu-icon-yellow">❓</view>
      <text class="menu-title">帮助与反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-line menu-line-last" bindtap="onAbout">
      <view class="menu-icon menu-icon-gray">ℹ️</view>
      <text class="menu-title">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="card logout-card" bindtap="logout">
    <view class="menu-line menu-line-last logout-line">
      <view class="menu-icon menu-icon-red">🚪</view>
      <text class="menu-title logout-title">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
