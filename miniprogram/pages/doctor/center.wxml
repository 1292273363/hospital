<view class="doctor-center-page">
  <view class="profile-card">
    <view class="name">{{userInfo.nickName || '医生'}}</view>
    <view class="line">手机号：{{userInfo.phone || '-'}}</view>
    <view class="line">角色：医生</view>
  </view>

  <view class="menu-card">
    <view class="menu-item" bindtap="goChat">
      <text>在线沟通</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goHome">
      <text>返回医生首页</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item danger" bindtap="logout">
      <text>退出登录</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
