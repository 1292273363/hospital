page {
  background-color: #f0f9f8;
}

.detail-page {
  padding: 32rpx 28rpx 40rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 0 20rpx rgba(225, 231, 243, 0.9);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.top-row {
  display: flex;
  flex-direction: row;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #d1f0ec;
  color: #248274;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 16rpx;
}

.status-tag {
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
}

.st-pending {
  background: #fffbe6;
  color: #d48806;
}

.st-treating {
  background: #e6f4ff;
  color: #1677ff;
}

.st-done {
  background: #f6ffed;
  color: #389e0d;
}

.meta {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-top: 6rpx;
}

.section-card .section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.project {
  font-size: 26rpx;
  color: #666666;
}

.field-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.field-label {
  font-size: 26rpx;
  color: #999999;
}

.field-value {
  font-size: 26rpx;
  color: #333333;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

