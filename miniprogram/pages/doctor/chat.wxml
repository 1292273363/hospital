<view class="doctor-chat-page">
  <!-- 患者信息头部 -->
  <view class="chat-header">
    <image class="avatar-large" src="{{patient.avatar}}" mode="aspectFill" />
    <view class="header-info">
      <text class="header-name">{{patient.name}}</text>
      <text class="header-desc">{{patient.statusText}}</text>
    </view>
      <button class='header-more' bindtap="onViewPatientDetail">
       i
      </button>
  </view>

  <!-- 聊天内容 -->
  <scroll-view
    class="chat-scroll"
    scroll-y="true"
    scroll-with-animation="true"
    scroll-into-view="{{scrollIntoView}}"
  >
    <view class="chat-inner">
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="msg-row {{item.from === 'doctor' ? 'msg-row-doctor' : 'msg-row-patient'}}"
      >
        <!-- 患者气泡 -->
        <block wx:if="{{item.from === 'patient'}}">
          <image class="avatar-small" src="{{patient.avatar}}" mode="aspectFill" />
          <view class="msg-block">
            <view wx:if="{{item.type === 'text'}}" class="bubble bubble-patient">
              <text class="bubble-text">{{item.content}}</text>
            </view>
            <image
              wx:if="{{item.type === 'image'}}"
              class="image-msg"
              src="{{item.imageUrl}}"
              mode="aspectFill"
            />
            <text class="time time-left">{{item.time}}</text>
          </view>
        </block>

        <!-- 医生气泡 -->
        <block wx:elif="{{item.from === 'doctor'}}">
          <view class="msg-block msg-block-doctor">
            <view wx:if="{{item.type === 'text'}}" class="bubble bubble-doctor">
              <text class="bubble-text">{{item.content}}</text>
            </view>
            <text class="time time-right">{{item.time}}</text>
          </view>
          <image class="avatar-small" src="{{doctorAvatar}}" mode="aspectFill" />
        </block>
      </view>
    </view>
  </scroll-view>

<!-- 底部输入区域（参考图二比例） -->
<view class="footer-bar">
  <view class="input-box">
    <!-- 附件图标占位：后续你可替换为真实图标路径 -->
    <view class="icon-btn">
      <text class="icon-text">📎</text>
    </view>

    <!-- 图片图标占位 -->
    <view class="icon-btn">
      <text class="icon-text">🖼</text>
    </view>

    <!-- 主输入框 -->
    <input
      class="text-input"
      placeholder="输入消息..."
      placeholder-class="placeholder-style"
      value="{{draft}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="onSend"
    />

    <!-- 发送按钮（图标占位） -->
    <button class="send-btn" bindtap="onSend">
      <text>➤</text>
    </button>
  </view>
</view>
</view>
