<view class="record-page">
  <view class="card head-card">
    <view class="title-row">
      <text class="title-main">诊断档案</text>
      <text class="title-sub">患者：{{patientName}}</text>
    </view>
    <text class="head-tip">以下为患者上传的检查报告、诊断记录等，仅供医疗使用</text>
  </view>

  <view class="card" wx:if="{{records.length}}">
    <block wx:for="{{records}}" wx:key="id">
      <view class="record-item">
        <view class="record-left">
          <view class="file-icon">{{item.type === 'image' ? '图' : '文'}}</view>
          <view class="record-info">
            <text class="record-name">{{item.name}}</text>
            <text class="record-meta">{{item.date}} · {{item.remark}}</text>
          </view>
        </view>
        <button class="btn-view" size="mini" bindtap="onPreview" data-id="{{item.id}}">
          查看
        </button>
      </view>
      <view class="divider" wx:if="{{index < records.length - 1}}"></view>
    </block>
  </view>

  <view class="empty" wx:if="{{!records.length}}">
    <text>暂无诊断档案</text>
  </view>
</view>

