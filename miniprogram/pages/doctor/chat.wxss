.doctor-chat-page {
  min-height: 100vh;
  background: #f0f9f8;
  padding: 24rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.chat-header {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 0 20rpx rgba(225, 231, 243, 0.9);
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-large {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.header-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.header-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.header-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #888888;
}

.header-more {
  flex: 0.12;
  height: 56rpx;
  border-radius: 999rpx;
  background: #f0f9f8;
  color: #248274;
  text-align: center;
  line-height: 56rpx;
  font-size: 26rpx;
  padding: 0;
  font-weight: 700;
}

.header-more::after {
  border: none;
}

.chat-scroll {
  height: calc(100vh - 260rpx);
}

.chat-inner {
  padding: 16rpx 4rpx 24rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 20rpx;
}

.msg-row-patient {
  justify-content: flex-start;
}

.msg-row-doctor {
  justify-content: flex-end;
}

.avatar-small {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.msg-block {
  max-width: 70%;
  margin-left: 12rpx;
}

.msg-block-doctor {
  margin-left: 0;
  margin-right: 12rpx;
  align-items: flex-end;
}

.bubble {
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  box-shadow: 0 0 12rpx rgba(0, 0, 0, 0.04);
}

.bubble-patient {
  background: #f0f9f8;
  color: #19453e;
  border-radius: 16rpx 16rpx 16rpx 4rpx;
}

.bubble-doctor {
  background: #30a392;
  color: #ffffff;
  border-radius: 16rpx 16rpx 4rpx 16rpx;
}

.bubble-text {
  white-space: pre-wrap;
}

.image-msg {
  width: 280rpx;
  height: 360rpx;
  border-radius: 16rpx;
  margin-top: 6rpx;
}

.time {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999999;
}

.time-left {
  text-align: left;
}

.time-right {
  text-align: right;
}

.chat-input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx 24rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.input-shell {
  flex: 1;
  height: 76rpx;
  border-radius: 999rpx;
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  padding: 0 0rpx;
  margin-right: 16rpx;
  box-sizing: border-box;
}

.icon-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: transparent;
  color: #248274;
  font-size: 28rpx;
  text-align: center;
  line-height: 52rpx;
  padding: 0;
  margin-right: 0;
}

.icon-btn::after {
  border: none;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  padding: 0 22rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #333333;
  margin-left: 12rpx;
}

.chat-input-ph {
  color: #b3b3b3;
  opacity: 1;
}

.send-btn {
  height: 72rpx;
  width: 40rpx;
  border-radius: 999rpx;
  background: #30a392;
  color: #ffffff;
  font-size: 26rpx;
}

.send-btn::after {
  border: none;
}
/* 底部固定栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-top: 1rpx solid #e5e7eb; /* gray-200 */
  padding: 10rpx 20rpx;
  z-index: 999; /* 防止被其他内容遮挡 */
  /* 适配 iPhone X 底部安全区 */
  padding-bottom: calc(env(safe-area-inset-bottom));
}

/* 内部 Flex 布局容器 */
.input-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

/* 图标按钮通用样式 */
.icon-btn {
  width: 56rpx;
  height: 56rpx;
  padding: 4rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 32rpx;
  color: #248274;
}

/* 自定义图标大小 */
.custom-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 输入框样式 */
.text-input {
  flex: 1 1 auto;
  height: 72rpx;
  padding: 0 24rpx;
  background-color: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 36rpx; /* 圆角 */
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 输入框占位符颜色 */
.placeholder-style {
  color: #9ca3af;
}

/* 输入框聚焦时的边框颜色 (微信部分版本支持) */
.text-input:focus {
  border-color: #0d9488; /* medical-500 */
}

/* 发送按钮样式 */
.send-btn {
  background-color: #14b8a6; /* medical-500 (假设的医疗绿) */
  color: #ffffff;
  padding: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0; /* 清除默认 margin */
  flex: 0 0 120rpx;
  width: 120rpx;
  min-width: 0;
}

.send-btn::after {
  border: none; /* 去除按钮默认边框 */
}

.send-btn:active {
  background-color: #0f766e; /* medical-600 (按下效果) */
}

.send-icon {
  width: 32rpx;
  height: 32rpx;
}