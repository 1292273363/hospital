<view class="patients-page">
  <!-- 搜索 -->
  <view class="search-wrap">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      type="text"
      placeholder="搜索患者姓名或手机号"
      placeholder-class="search-ph"
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
    />
  </view>

  <!-- 筛选 -->
  <scroll-view class="filter-scroll" scroll-x="{{true}}" enable-flex="{{true}}">
    <view class="filter-inner">
      <view
        wx:for="{{filterTabs}}"
        wx:key="key"
        class="filter-chip {{selectedFilter === item.key ? 'filter-chip-on' : ''}}"
        data-key="{{item.key}}"
        bindtap="onFilterTap"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <!-- 列表 -->
  <view class="card-list">
    <view class="patient-card" wx:for="{{displayList}}" wx:key="id">
      <view class="card-top">
        <view class="card-left">
          <view class="p-avatar">{{item.avatarText}}</view>
          <view class="p-info">
            <text class="p-name">{{item.name}}</text>
            <text class="p-meta">{{item.gender}} · {{item.age}}岁 · {{item.phone}}</text>
            <view class="p-tags">
              <text class="status-tag {{item.statusClass}}">{{item.status}}</text>
            </view>
          </view>
        </view>
        <text class="p-date">{{item.date}}</text>
      </view>
      <view class="card-divider"></view>
      <text class="p-project">咨询项目：{{item.project}}</text>
      <view class="card-actions">
        <button class="btn btn-outline" bindtap="onViewRecord" data-id="{{item.id}}">查看档案</button>
        <button class="btn btn-primary" bindtap="onViewDetail" data-id="{{item.id}}">查看详情</button>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{displayList.length > 0}}">
    <text>加载更多...</text>
  </view>
  <view class="empty-tip" wx:if="{{displayList.length === 0}}">
    <text>暂无符合条件的患者</text>
  </view>
</view>
