<view class="doctor-login-page">
  <view class="header">
    <view class="header-icon-wrap">
      <view class="header-icon-inner">
        <text class="header-icon-symbol">医</text>
      </view>
    </view>
    <view class="header-title">医生登录</view>
    <view class="header-sub">欢迎进入整形医院服务系统</view>
  </view>

  <view class="card">
    <view class="tabs">
      <view
        class="tab {{loginTab === 'code' ? 'tab-active' : ''}}"
        data-tab="code"
        bindtap="onTabChange"
      >
        验证码登录
      </view>
      <view
        class="tab {{loginTab === 'password' ? 'tab-active' : ''}}"
        data-tab="password"
        bindtap="onTabChange"
      >
        密码登录
      </view>
    </view>

    <block wx:if="{{loginTab === 'code'}}">
      <view class="field-label">手机号</view>
      <view class="input-wrap">
        <text class="input-icon" aria-hidden="true">📱</text>
        <input
          class="input-field"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="input-ph"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <view class="field-label">验证码</view>
      <view class="code-row">
        <view class="input-wrap code-input-wrap">
          <text class="input-icon" aria-hidden="true">🔑</text>
          <input
            class="input-field"
            type="number"
            maxlength="6"
            placeholder="请输入验证码"
            placeholder-class="input-ph"
            value="{{code}}"
            bindinput="onCodeInput"
          />
        </view>
        <button
          class="code-btn"
          bindtap="sendCode"
          disabled="{{sendingCode || countdown > 0}}"
        >
          <text class="code-btn-text">{{countdown > 0 ? countdown + 's' : (sendingCode ? '发送中' : '获取验证码')}}</text>
        </button>
      </view>
    </block>

    <block wx:else>
      <view class="field-label">手机号</view>
      <view class="input-wrap">
        <text class="input-icon" aria-hidden="true">📱</text>
        <input
          class="input-field"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="input-ph"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <view class="field-label">密码</view>
      <view class="input-wrap">
        <text class="input-icon" aria-hidden="true">🔒</text>
        <input
          class="input-field"
          password
          placeholder="请输入登录密码"
          placeholder-class="input-ph"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>
    </block>

    <button
      class="login-btn"
      bindtap="submitLogin"
      loading="{{loggingIn}}"
      disabled="{{loggingIn}}"
    >
      <text class="login-btn-text">登录</text>
    </button>

    <view class="card-footer">
      <text class="card-footer-link card-footer-link-blue" bindtap="onForgotPassword">忘记密码？</text>
      <text class="card-footer-link" bindtap="goPatientLogin">切换到患者登录 ></text>
    </view>
  </view>
</view>
