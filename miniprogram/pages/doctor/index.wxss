/* 医生端首页 — medical 主题（对齐参考 HTML） */
page {
  background-color: #f0f9f8;
}

.doctor-page {
  min-height: 100vh;
  padding: 32rpx 28rpx;
  padding-bottom: calc(32rpx + 120rpx + env(safe-area-inset-bottom));
  background: #f0f9f8;
  box-sizing: border-box;
}

/* 欢迎横幅 from-medical-500 to-medical-400 */
.welcome-card {
  background: linear-gradient(90deg, #30a392 0%, #49bcac 100%);
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(48, 163, 146, 0.35);
  padding: 40rpx 32rpx;
  margin-bottom: 48rpx;
  color: #ffffff;
}

.welcome-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.welcome-greet {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.welcome-line2 {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
}

.welcome-sub {
  font-size: 26rpx;
  opacity: 0.92;
}

.welcome-num {
  font-size: 40rpx;
  font-weight: 700;
  margin: 0 8rpx;
  opacity: 1;
}

.welcome-right {
  text-align: right;
}

.date-line {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
}

.date-line + .date-line {
  margin-top: 8rpx;
}

.section-card {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 0 20rpx 0 rgba(225, 231, 243, 0.9);
  padding: 32rpx;
  margin-bottom: 48rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1c534b;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #30a392;
}

.section-more .chev {
  margin-left: 4rpx;
  font-size: 28rpx;
}

.patient-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.patient-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  background: #fafafa;
}

.patient-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #d1f0ec;
  color: #248274;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.patient-main {
  flex: 1;
  min-width: 0;
}

.patient-row1 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.patient-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.tag-warning {
  background: rgba(250, 173, 20, 0.12);
  color: #d48806;
}

.tag-primary {
  background: rgba(22, 119, 255, 0.1);
  color: #1677ff;
}

.tag-error {
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.patient-desc {
  font-size: 24rpx;
  color: #888888;
  margin-top: 8rpx;
  display: block;
}

.patient-arrow {
  font-size: 36rpx;
  color: #dddddd;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.quick-section {
  margin-bottom: 48rpx;
}

.quick-heading {
  font-size: 34rpx;
  font-weight: 600;
  color: #1c534b;
  display: block;
  margin-bottom: 28rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.quick-item {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 0 20rpx 0 rgba(225, 231, 243, 0.9);
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-icon-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  position: relative;
}

.quick-icon-wrap.rel {
  position: relative;
}

.bg-medical {
  background: #d1f0ec;
}

.bg-blue {
  background: #e6f4ff;
}

.bg-yellow {
  background: #fffbe6;
}

.bg-green {
  background: #f6ffed;
}

.quick-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.notify-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 8rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 18rpx;
  text-align: center;
}

.quick-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #444444;
  text-align: center;
}

.stats-card {
  margin-bottom: 0;
}

.stats-title {
  display: block;
  margin-bottom: 28rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  text-align: center;
}

.stat-box {
  padding: 16rpx 8rpx;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #248274;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #888888;
  margin-top: 8rpx;
  display: block;
}
