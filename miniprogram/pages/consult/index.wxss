.consult-container {
  min-height: 100vh;
  background: #f5fbf9;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 18rpx;
}

.picker {
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #333;
}

.btn {
  margin-top: 18rpx;
  background: #43a294;
  color: #fff;
  border-radius: 42rpx;
}

.report-item {
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.k {
  color: #666;
}

.v {
  color: #333;
}

.report-text {
  margin-top: 16rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.upload-box {
  height: 280rpx;
  border: 2rpx dashed #b9dcd8;
  border-radius: 16rpx;
  background: #f8fcfb;
  overflow: hidden;
}

.upload-placeholder {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6a9a94;
  font-size: 28rpx;
}

.preview {
  width: 100%;
  height: 100%;
}

.textarea {
  margin-top: 18rpx;
  width: 100%;
  min-height: 180rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #f7f8fa;
  padding: 20rpx;
  font-size: 28rpx;
}

.submit-btn {
  margin-top: 24rpx;
}

.history-empty {
  color: #999;
  font-size: 26rpx;
}

.history-item {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid #f1f1f1;
  padding-top: 16rpx;
}

.history-image {
  width: 132rpx;
  height: 132rpx;
  border-radius: 12rpx;
  background: #eee;
  flex-shrink: 0;
}

.history-content {
  flex: 1;
}

.history-time {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.history-msg,
.history-reply {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}
