<view class="consult-container">
  <view class="card">
    <view class="title">1. 当前患者档案</view>
    <view class="picker" wx:if="{{currentPatient}}">
      {{currentPatient.patientName}}（{{currentPatient.diseaseType || '未填写病种'}}）
    </view>
    <view class="picker" wx:else>未选择患者档案，请先到中心选择</view>
    <button class="btn" wx:if="{{!currentPatient}}" bindtap="goPatientSelect">去中心选择患者</button>
  </view>

  <view class="card">
    <view class="title">2. 选择专家看诊记录</view>
    <picker mode="selector" range="{{visitOptions}}" range-key="label" value="{{visitIndex}}" bindchange="onVisitChange">
      <view class="picker">{{visitOptions.length ? visitOptions[visitIndex].label : '该患者暂无可用专家看诊记录'}}</view>
    </picker>
    <button class="btn" bindtap="loadReport" disabled="{{!currentPatient || !visitOptions.length}}">查看诊断报告</button>
  </view>

  <view class="card" wx:if="{{reportLoaded}}">
    <view class="title">3. 医生诊断报告</view>
    <view class="report-item"><text class="k">医生：</text><text class="v">{{report.doctorName}}（{{report.doctorLevel}}）</text></view>
    <view class="report-item"><text class="k">时间：</text><text class="v">{{report.visitTime}}</text></view>
    <view class="report-text">{{report.diagnosisReport || '暂无诊断报告'}}</view>
  </view>

  <view class="card" wx:if="{{reportLoaded}}">
    <view class="title">4. 上传新疤痕图片并留言</view>
    <view class="upload-box" bindtap="chooseImage">
      <image wx:if="{{scarImageUrl}}" class="preview" src="{{scarImageUrl}}" mode="aspectFill" />
      <view wx:else class="upload-placeholder">点击上传疤痕图片</view>
    </view>
    <textarea class="textarea" placeholder="请输入留言，便于专家线上诊断" value="{{message}}" bindinput="onMessageInput" />
    <button class="btn submit-btn" loading="{{submitting}}" bindtap="submitConsult">提交线上问诊</button>
  </view>

  <view class="card" wx:if="{{currentPatient}}">
    <view class="title">该患者在线问诊记录</view>
    <view class="history-empty" wx:if="{{!historyList.length}}">暂无在线问诊记录</view>
    <view class="history-item" wx:for="{{historyList}}" wx:key="id">
      <image class="history-image" src="{{item.scarImageUrl}}" mode="aspectFill" />
      <view class="history-content">
        <view class="history-time">{{item.createTime}} · {{item.status}}</view>
        <view class="history-msg">留言：{{item.patientMessage || '无'}}</view>
        <view class="history-reply">专家回复：{{item.doctorReply || '暂未回复'}}</view>
      </view>
    </view>
  </view>
</view>
