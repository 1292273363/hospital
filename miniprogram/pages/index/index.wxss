/* 患者端主页 — medical 色板（对齐参考 HTML） */
page {
  background-color: #f0f9f8;
}

.index-page {
  min-height: 100vh;
  background: #f0f9f8;
  padding-bottom: calc(40rpx + 120rpx + env(safe-area-inset-bottom));
}

.page-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}

.page-top-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #19453e;
}

.page-top-logout {
  font-size: 26rpx;
  color: #248274;
  padding: 8rpx 20rpx;
  background: #d1f0ec;
  border-radius: 8rpx;
}

.content-wrap {
  padding: 0 32rpx 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 0 20rpx 0 rgba(225, 231, 243, 0.9);
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.card-last {
  margin-bottom: 0;
}

/* 用户卡片 */
.user-row {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.user-avatar-ph {
  background: #d1f0ec;
  color: #248274;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-meta {
  margin-left: 32rpx;
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.user-id {
  font-size: 26rpx;
  color: #888888;
  margin-top: 8rpx;
  display: block;
}

.user-badge {
  margin-top: 16rpx;
  display: inline-block;
  padding: 8rpx 24rpx;
  background: #e8f5e9;
  color: #2e7d32;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.card-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 0;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.divider-top {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
  margin-top: 24rpx;
}

.kv-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.kv-row-last {
  margin-bottom: 0;
}

.kv-label {
  font-size: 28rpx;
  color: #666666;
}

.kv-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  text-align: right;
  max-width: 60%;
}

.bind-btn {
  margin-top: 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  border-radius: 36rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #4ecdc4, #38a89d);
}

.bind-btn::after {
  border: none;
}

.section-heading {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

/* 2×2 快捷入口 */
.quick-grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
  margin-bottom: 40rpx;
}

.quick-tile {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 0 20rpx 0 rgba(225, 231, 243, 0.9);
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-tile-disabled {
  opacity: 0.45;
}

.quick-icon-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #d1f0ec;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.quick-icon {
  font-size: 48rpx;
  line-height: 1;
}

.quick-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  text-align: center;
}

/* 就诊提醒 */
.reminder-box {
  border-left: 8rpx solid #faad14;
  padding-left: 24rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
  margin-top: 24rpx;
}

.reminder-main {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  display: block;
  margin-bottom: 8rpx;
}

.reminder-sub {
  font-size: 24rpx;
  color: #888888;
}

/* 公告列表 */
.notice-items {
  margin-top: 24rpx;
}

.notice-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.notice-row + .notice-row {
  border-top: 1rpx solid #f5f5f5;
}

.notice-bullet {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #30a392;
  margin-top: 16rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-body {
  flex: 1;
  min-width: 0;
}

.notice-title {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.4;
}

.notice-date {
  font-size: 22rpx;
  color: #888888;
  margin-top: 8rpx;
  display: block;
}
