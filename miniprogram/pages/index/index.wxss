/* pages/index/index.wxss */

.index-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* 顶部用户信息 */
.header {
  background: linear-gradient(135deg, #1AAD19 0%, #0d8a0c 100%);
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
}

.avatar-placeholder {
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.25);
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.user-tag {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-top: 6rpx;
}

.logout-btn {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.2);
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
}

/* 章节标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  padding: 36rpx 40rpx 20rpx;
}

/* 快速入口网格 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 0 30rpx;
  background: #fff;
  padding: 30rpx;
  margin: 0 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
}

.grid-icon {
  font-size: 52rpx;
  line-height: 1;
  width: 90rpx;
  height: 90rpx;
  background: #f0faf0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.grid-label {
  font-size: 24rpx;
  color: #555;
  text-align: center;
}

/* 公告列表 */
.notice-list {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 24rpx;
  padding: 10rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.notice-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #1AAD19;
  flex-shrink: 0;
}

.notice-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-time {
  font-size: 22rpx;
  color: #bbb;
  flex-shrink: 0;
}

