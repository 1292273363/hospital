<!-- 患者端主页 — 参考医疗主题卡片布局 -->
<view class="index-page">
  <view class="page-top">
    <text class="page-top-title">整形医院服务系统</text>
    <text class="page-top-logout" bindtap="onLogout">退出</text>
  </view>

  <view class="content-wrap">
    <!-- 用户信息卡片 -->
    <view class="card card-user">
      <view class="user-row">
        <image
          wx:if="{{userInfo.avatarUrl}}"
          class="user-avatar"
          src="{{userInfo.avatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="user-avatar user-avatar-ph">头像</view>
        <view class="user-meta">
          <text class="user-name">{{userInfo.nickName || '微信用户'}}</text>
          <text class="user-id">ID: {{userDisplayId}}</text>
          <view class="user-badge">就诊中</view>
        </view>
      </view>
    </view>

    <!-- 当前就诊状态 -->
    <view class="card">
      <view class="card-title-row">
        <text class="title-icon">📋</text>
        <text class="card-title">当前就诊状态</text>
      </view>
      <view class="divider-top">
        <view class="kv-row">
          <text class="kv-label">主治医师</text>
          <text class="kv-value">{{visitStatus.doctorName}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-label">就诊类型</text>
          <text class="kv-value">{{visitStatus.visitType}}</text>
        </view>
        <view class="kv-row kv-row-last">
          <text class="kv-label">最近更新</text>
          <text class="kv-value">{{visitStatus.lastUpdate}}</text>
        </view>
        <button wx:if="{{!binding.bound}}" class="bind-btn" bindtap="onBindDoctorTap">选择主治医生并绑定</button>
      </view>
    </view>

    <!-- 快捷功能 2×2 -->
    <view class="section-heading">快捷功能</view>
    <view class="quick-grid-2">
      <view
        class="quick-tile {{!binding.bound ? 'quick-tile-disabled' : ''}}"
        wx:for="{{quickMenus}}"
        wx:key="id"
        bindtap="onMenuTap"
        data-id="{{item.id}}"
      >
        <view class="quick-icon-wrap">
          <text class="quick-icon">{{item.icon}}</text>
        </view>
        <text class="quick-label">{{item.label}}</text>
      </view>
    </view>

    <!-- 就诊提醒 -->
    <view class="card">
      <view class="card-title-row">
        <text class="title-icon title-icon-warn">🔔</text>
        <text class="card-title">就诊提醒</text>
      </view>
      <view class="reminder-box">
        <text class="reminder-main">{{visitReminder.content}}</text>
        <text class="reminder-sub">发布时间：{{visitReminder.time}}</text>
      </view>
    </view>

    <!-- 医院公告 -->
    <view class="card card-last">
      <view class="card-title-row">
        <text class="title-icon">📢</text>
        <text class="card-title">医院公告</text>
      </view>
      <view class="notice-items">
        <view class="notice-row" wx:for="{{notices}}" wx:key="id">
          <view class="notice-bullet"></view>
          <view class="notice-body">
            <text class="notice-title">{{item.title}}</text>
            <text class="notice-date">{{item.time}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
